{
  "name": "bili-party-win",
  "version": "1.0.0",
  "description": "一起看B站视频 - 猫爪同步",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "author": "汀酱",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "productName": "BiliParty",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": null
    },
    "portable": {
      "artifactName": "BiliParty_${version}.exe"
    }
  }
}